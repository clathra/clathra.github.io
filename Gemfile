source "https://rubygems.org"

# Jekyll 3.10.x matches the version GitHub Pages builds with, for parity.
gem "jekyll", "~> 3.10.0"

# GitHub-Flavored Markdown parser (matches GitHub Pages; needed for `input: GFM`).
gem "kramdown-parser-gfm", "~> 1.1"

# Auto-generates sitemap.xml from all pages/posts (GitHub Pages supported).
gem "jekyll-sitemap", "~> 1.4"

# webrick is no longer bundled with Ruby 3+, needed for `jekyll serve`.
gem "webrick", "~> 1.8"
